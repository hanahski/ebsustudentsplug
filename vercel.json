{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "www.ebsustudentsplug.fun" }
      ],
      "destination": "https://ebsustudentsplug.fun/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://sp-origin.lovable.app/api/:path*"
    },
    {
      "source": "/_serverFn/:path*",
      "destination": "https://sp-origin.lovable.app/_serverFn/:path*"
    },
    {
      "source": "/lovable/:path*",
      "destination": "https://sp-origin.lovable.app/lovable/:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://sp-origin.lovable.app/sitemap.xml"
    }
  ]
}
